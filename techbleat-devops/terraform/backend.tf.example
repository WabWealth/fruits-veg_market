# Rename to backend.tf and run: terraform init -backend-config=backend.hcl
# Required for Jenkins to share Terraform state.
#
# 1. Create S3 bucket: aws s3 mb s3://techbleat-tfstate-$(aws sts get-caller-identity --query Account --output text) --region eu-west-1
# 2. Create DynamoDB: aws dynamodb create-table --table-name techbleat-tfstate-lock --attribute-definitions AttributeName=LockID,AttributeType=S --key-schema AttributeName=LockID,KeyType=HASH --billing-mode PAY_PER_REQUEST --region eu-west-1
# 3. Copy backend.hcl.example to backend.hcl, set bucket name
# 4. terraform init -backend-config=backend.hcl -migrate-state

terraform {
  backend "s3" {
    key = "techbleat/terraform.tfstate"
    # bucket, region, dynamodb_table from backend.hcl
  }
}
