// -----------------------------------------------------------------------------
// Techbleat Superstore - Jenkins CI/CD Pipeline
// -----------------------------------------------------------------------------

pipeline {
    agent any

    environment {
        AWS_REGION = 'eu-west-1'
    }

    parameters {
        booleanParam(
            name: 'DEPLOY_APP',
            defaultValue: false,
            description: 'Deploy application to EC2 after Terraform'
        )
        string(
            name: 'DOMAIN_NAME',
            defaultValue: 'techbleat-market.duckdns.org',
            description: 'DuckDNS domain for HTTPS (e.g. techbleat-market.duckdns.org). Create at duckdns.org, add credential duckdns-token.'
        )
        string(
            name: 'CERTBOT_EMAIL',
            defaultValue: '',
            description: 'Email for Let\'s Encrypt'
        )
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo 'Code checked out from repository'
            }
        }

        stage('Terraform Init') {
            steps {
                dir('techbleat-devops/terraform') {
                    sh 'if [ -f backend.hcl ]; then terraform init -backend-config=backend.hcl; else terraform init; fi'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('techbleat-devops/terraform') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('techbleat-devops/terraform') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Update DuckDNS') {
            when {
                expression { return params.DEPLOY_APP }
            }
            steps {
                withCredentials([string(credentialsId: 'duckdns-token', variable: 'DUCKDNS_TOKEN')]) {
                    sh """
                        set -e
                        cd techbleat-devops/terraform
                        EC2_IP=\$(terraform output -raw server_public_ip)
                        SUBDOMAIN=\$(echo "${params.DOMAIN_NAME}" | cut -d. -f1)
                        curl -s "https://www.duckdns.org/update?domains=\$SUBDOMAIN&token=\$DUCKDNS_TOKEN&ip=\$EC2_IP"
                        echo ""
                        echo "DuckDNS updated: \$SUBDOMAIN.duckdns.org -> \$EC2_IP"
                    """
                }
            }
        }

        stage('Deploy Application') {
            when {
                expression { return params.DEPLOY_APP }
            }
            steps {
                script {
                    if (!params.DOMAIN_NAME?.trim() || !params.CERTBOT_EMAIL?.trim()) {
                        error "DEPLOY_APP requires DOMAIN_NAME and CERTBOT_EMAIL"
                    }
                    if (!params.DOMAIN_NAME.contains('duckdns.org')) {
                        error "Use a DuckDNS domain (e.g. techbleat-market.duckdns.org). Create at duckdns.org and add credential duckdns-token."
                    }
                }
                withCredentials([
                    sshUserPrivateKey(
                        credentialsId: 'techbleat-ec2-key',
                        keyFileVariable: 'SSH_KEY_PATH'
                    )
                ]) {
                    sh """
                        set -e
                        cd techbleat-devops/terraform
                        EC2_IP=\$(terraform output -raw server_public_ip)
                        DB_URL=\$(terraform output -raw database_url)
                        cd ../..
                        DOMAIN="${params.DOMAIN_NAME}"
                        SSH_OPTS="-i \$SSH_KEY_PATH -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

                        echo "Deploying to \$EC2_IP (domain: \$DOMAIN) ..."

                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "mkdir -p /home/ec2-user/app"

                        rsync -avz -e "ssh \$SSH_OPTS" \\
                          --exclude venv --exclude __pycache__ --exclude .git \\
                          backend-api/ ec2-user@\$EC2_IP:/home/ec2-user/app/

                        echo "DATABASE_URL=\$DB_URL" > /tmp/app.env
                        scp \$SSH_OPTS /tmp/app.env ec2-user@\$EC2_IP:/home/ec2-user/app/.env
                        rm -f /tmp/app.env

                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "mkdir -p /tmp/frontend-deploy"
                        rsync -avz -e "ssh \$SSH_OPTS" \\
                          --exclude nginx.conf_sample --exclude techbleat.conf \\
                          frontend/ ec2-user@\$EC2_IP:/tmp/frontend-deploy/

                        scp \$SSH_OPTS techbleat-devops/nginx/techbleat.conf ec2-user@\$EC2_IP:/tmp/techbleat.conf
                        scp \$SSH_OPTS techbleat-devops/backend/fastapi.service ec2-user@\$EC2_IP:/tmp/fastapi.service

                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo amazon-linux-extras install nginx1 -y 2>/dev/null || sudo yum install -y nginx"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo yum install -y python3 python3-pip"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo systemctl enable nginx && sudo systemctl start nginx"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo cp -r /tmp/frontend-deploy/* /usr/share/nginx/html/"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo cp /tmp/techbleat.conf /etc/nginx/conf.d/techbleat.conf"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "cd /home/ec2-user/app && python3 -m venv venv 2>/dev/null || true && ./venv/bin/pip install -r requirements.txt -q"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo cp /tmp/fastapi.service /etc/systemd/system/fastapi.service && sudo systemctl daemon-reload"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo systemctl enable fastapi && sudo systemctl restart fastapi 2>/dev/null || sudo systemctl start fastapi"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo systemctl restart nginx"

                        echo "Setting up Nginx for \$DOMAIN ..."
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo sed -i 's/server_name _/server_name '\$DOMAIN'/' /etc/nginx/conf.d/techbleat.conf"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo systemctl reload nginx"

                        echo "Installing Certbot (Amazon Linux 2 compatible) ..."
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo amazon-linux-extras enable epel 2>/dev/null || true"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo yum install -y epel-release 2>/dev/null || true"
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo yum install -y certbot python2-certbot-nginx"

                        echo "Waiting 45s for DNS propagation before Certbot ..."
                        sleep 45

                        echo "Requesting Let's Encrypt certificate for \$DOMAIN ..."
                        ssh \$SSH_OPTS ec2-user@\$EC2_IP "sudo certbot --nginx -d \$DOMAIN --non-interactive --agree-tos -m ${params.CERTBOT_EMAIL}"

                        echo "Done. Visit https://\$DOMAIN and https://\$DOMAIN/api/products"
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully'
            dir('techbleat-devops/terraform') {
                sh 'terraform output'
            }
        }
        failure {
            echo 'Pipeline failed - check logs'
        }
    }
}
